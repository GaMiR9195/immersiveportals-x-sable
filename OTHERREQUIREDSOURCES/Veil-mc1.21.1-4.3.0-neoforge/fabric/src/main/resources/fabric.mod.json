{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "icon": "icon.png",
  "authors": [
    ${mod_authors}
  ],
  "contributors": [
    ${mod_contributors}
  ],
  "contact": {
    "homepage": "https://modrinth.com/project/veil",
    "issues": "https://github.com/FoundryMC/Veil/issues",
    "sources": "https://github.com/FoundryMC/Veil"
  },
  "license": "${license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "foundry.veil.fabric.VeilFabric"
    ],
    "client": [
      "foundry.veil.fabric.VeilFabricClient"
    ]
  },
  "custom": {
    "fabric-renderer-indigo:force_compatibility": true,
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.com/invite/2aqTX9QWKU",
        "modmenu.modrinth": "https://modrinth.com/mod/veil",
        "modmenu.wiki": "https://github.com/FoundryMC/Veil/wiki"
      }
    }
  },
  "mixins": [
    "${mod_id}.command.mixins.json",
    "${mod_id}.debug.mixins.json",
    "${mod_id}.dynamicbuffer.mixins.json",
    "${mod_id}.fix.mixins.json",
    "${mod_id}.framebuffer.mixins.json",
    "${mod_id}.network.mixins.json",
    "${mod_id}.necromancer.mixins.json",
    "${mod_id}.performance.mixins.json",
    "${mod_id}.perspective.mixins.json",
    "${mod_id}.pipeline.mixins.json",
    "${mod_id}.quasar.mixins.json",
    "${mod_id}.registry.mixins.json",
    "${mod_id}.rendertype.mixins.json",
    "${mod_id}.resource.mixins.json",
    "${mod_id}.shader.mixins.json",
    "${mod_id}.scheduler.mixins.json",
    "${mod_id}.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-registry-sync-v0": ">=${fabric_version}",
    "fabric-lifecycle-events-v1": ">=${fabric_version}",
    "fabric-resource-loader-v0": ">=${fabric_version}",
    "fabric-networking-api-v1": ">=${fabric_version}",
    "fabric-command-api-v2": ">=${fabric_version}",
    "fabric-key-binding-api-v1": ">=${fabric_version}",
    "fabric-rendering-v1": ">=${fabric_version}",
    "fabric-renderer-api-v1": ">=${fabric_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=${java_version}"
  },
  "breaks": {
    "sodium": "<${sodium_version}",
    "embeddium": "*",
    "celeritas": "*",
    "imguimc": ["<${imguimc_version}", ">=2.0.0"]
  },
  "accessWidener": "veil.accesswidener"
}
  
